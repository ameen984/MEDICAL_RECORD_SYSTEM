NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/medical-records
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24h
FRONTEND_URL=http://localhost:5174

# Email (SMTP) — leave blank to fall back to terminal logging in development
# NOTE: Use port 465 (SSL) in production — cloud providers (Render, Railway, Heroku)
# block outbound port 587. Port 465 is always allowed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=MediCare
