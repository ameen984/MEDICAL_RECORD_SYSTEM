NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/medical-records
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24h
FRONTEND_URL=http://localhost:5174

# Email — two options, Resend is recommended for production
# Option A: Resend (recommended — works on Render/Railway/Vercel, free 3k emails/month)
#   1. Sign up at resend.com
#   2. Add your sending domain (or use their sandbox for testing)
#   3. Create an API key and paste it below
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=MediCare

# Option B: SMTP (works locally, but Gmail blocks connections from cloud provider IPs)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password

# Google OAuth — get from Google Cloud Console
# https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Twilio SMS — for phone OTP verification
# https://console.twilio.com/
# If not set, OTP is logged to console (dev mode)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
